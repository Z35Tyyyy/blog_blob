# copy to .env for local development (npm run dev loads it via --env-file)

# MongoDB Atlas connection string (Database → Connect → Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# database name (created automatically on first write)
MONGODB_DB=blog_blob

# comma-separated frontend origins allowed to make mutating requests
# (your Vercel deployment URL; localhost is always allowed)
ALLOWED_ORIGINS=https://blog-blob.vercel.app

# shared key for GET /api/export/content — the sync-content GitHub Actions
# workflow authenticates with this; use the same value as the repo secret
EXPORT_KEY=generate-a-long-random-string

# PORT=4000
